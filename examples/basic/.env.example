# Copy to .env.local and fill in your values
# .env.local is gitignored automatically by Next.js

# ── Frappe backend URL ────────────────────────────────────────────────────────
# Local bench: set to your bench webserver_port (check sites/common_site_config.json)
FRAPPE_INTERNAL_URL=http://127.0.0.1:8000

# Docker: use the container name
# FRAPPE_INTERNAL_URL=http://frappe-backend:8000

# ── API Key (for Server Actions / mutations) ──────────────────────────────────
# Frappe Desk → Settings → Users → <user> → API Access → Generate Keys
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# ── Site name ─────────────────────────────────────────────────────────────────
FRAPPE_SITE_NAME=site1.localhost

# ── Baked into client bundle at BUILD TIME — no secrets ──────────────────────
NEXT_PUBLIC_FRAPPE_SITE=site1.localhost
